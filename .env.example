# Telegram-бот, созданный через @BotFather — общий для всех профилей/каналов,
# один бот может быть админом сразу в нескольких разных каналах
TELEGRAM_BOT_TOKEN=

# --- Профиль "prompty" (по умолчанию) ---
# Канал, куда постим: @username канала (бот должен быть в нём администратором)
# или числовой id канала (например -1001234567890)
TELEGRAM_CHANNEL_ID=

# --- Профиль "savings" (канал "Копейка") ---
# Для любого профиля кроме "prompty" переменная называется
# TELEGRAM_CHANNEL_ID_<ИМЯ_ПРОФИЛЯ_КАПСОМ>
TELEGRAM_CHANNEL_ID_SAVINGS=

# Ключ Google AI Studio (бесплатно, без карты): https://aistudio.google.com/apikey
# Общий для всех профилей
GEMINI_API_KEY=

# Модель Gemini. gemini-3.1-flash-lite — актуальная GA-модель с самым
# щедрым бесплатным лимитом (2.5-flash-lite больше не выдаётся новым
# пользователям, см. https://ai.google.dev/gemini-api/docs/deprecations)
GEMINI_MODEL=gemini-3.1-flash-lite

# Генерация обложек через Cloudflare Workers AI (FLUX.1 schnell) — бесплатно,
# без карты, 10 000 "нейронов"/день (~230 картинок). Без токена пост просто
# выходит без картинки (текстом) — без него настоятельно рекомендуется настроить.
# 1. Зарегистрируйся на https://dash.cloudflare.com (без карты)
# 2. Workers & Pages → Overview — справа увидишь Account ID
# 3. Profile → API Tokens → Create Token → шаблон "Workers AI (Read/Write)"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
